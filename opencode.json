{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "memory": {
      "type": "remote",
      "url": "http://localhost:8765/mcp",
      "enabled": true,
      "timeout": 10000
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 10000
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?features=docs",
      "enabled": true,
      "timeout": 30000
    }
  }
}
