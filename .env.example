# =============================================================================
# REQUIRED — fill these in before running pnpm dev
# =============================================================================

# Supabase — https://supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase DB — https://supabase.com > Project Settings > Database > Connection string > Session mode (URI)
DATABASE_URL=postgresql://postgres.your-project-id:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# =============================================================================
# OPTIONAL (requerido para alta de usuarios desde /admin/users)
# =============================================================================

# Service role — Project Settings > API (nunca en el cliente ni en NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# OPTIONAL — límites de subida de documentos (servidor)
# =============================================================================

# Tamaño máximo por archivo en MB (por defecto 25)
DOCUMENT_UPLOAD_MAX_MB=25
